# =============================================================================
# AI Stickies - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#
# Supabase keys: use the new "publishable key" and "secret key" format
# (not the legacy "anon key" / "service role key").
# Find them in your Supabase Dashboard > Project Settings > API.
# =============================================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# --- AI Providers (at least one required) ---
BFL_API_KEY=
FAL_API_KEY=
FIREWORKS_API_KEY=

# --- AI Model Overrides (optional) ---
# BFL_MODEL=flux-2-pro
# FAL_MODEL=fal-ai/nano-banana-2

# --- Session (optional, has defaults) ---
# SESSION_MAX_GENERATIONS=10
# SESSION_TTL_DAYS=1

# --- Storage (optional, has defaults) ---
# STORAGE_UPLOAD_BUCKET=uploads
# STORAGE_STICKER_BUCKET=stickers
# MAX_UPLOAD_SIZE_MB=10

# --- Generation (optional, has defaults) ---
# POLL_INTERVAL_MS=2000
# MAX_POLL_ATTEMPTS=60

# --- Feature Flags (optional, defaults shown) ---
# ENABLE_FLUX=true
# ENABLE_FAL=true
# ENABLE_MARKETPLACE_EXPORT=false
